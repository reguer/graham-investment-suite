{
  "name": "graham-investment-suite",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-local-bin.js vite",
    "build": "node scripts/run-local-bin.js vite build",
    "test": "node scripts/run-local-bin.js vitest run",
    "test:watch": "node scripts/run-local-bin.js vitest",
    "dev:safe": "node scripts/start-dashboard.js",
    "dev:stop": "node scripts/stop-dashboard.js",
    "deploy:pages": "node scripts/deploy-pages.js",
