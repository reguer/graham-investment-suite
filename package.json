{
  "name": "graham-investment-suite",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-node22.js scripts/run-local-bin.js vite",
    "build": "node scripts/run-node22.js scripts/run-local-bin.js vite build",
    "test": "node scripts/run-node22.js scripts/run-local-bin.js vitest run",
    "test:watch": "node scripts/run-node22.js scripts/run-local-bin.js vitest",
    "dev:safe": "node scripts/run-node22.js scripts/start-dashboard.js",
    "dev:stop": "node scripts/run-node22.js scripts/stop-dashboard.js",
    "deploy:pages": "node scripts/run-node22.js scripts/deploy-pages.js",
    "build:artifact": "node scripts/run-node22.js scripts/bundle-artifact.js",
    "weekly:screen": "node scripts/run-node22.js scripts/weekly-screen.js",
    "weekly:report": "node scripts/run-node22.js scripts/weekly-screen.js",
    "watchlist:analyze": "node scripts/run-node22.js scripts/analyze-watchlist.js",
    "universe:refresh": "node scripts/run-node22.js scripts/refresh-universe.js",
    "universe:refresh:requested": "node scripts/run-node22.js scripts/refresh-universe.js --requested-only",
    "runtime:init": "node scripts/run-node22.js scripts/init-runtime.js",
    "db:setup": "node scripts/run-node22.js scripts/db-setup.js",
    "db:add-company": "node scripts/run-node22.js scripts/add-company.js",
    "db:import": "node scripts/run-node22.js scripts/import-companies.js",
    "db:migrate-candidates": "node scripts/run-node22.js scripts/migrate-candidates.js",
    "fundamentals:update": "node scripts/run-node22.js scripts/update-fundamentals.js",
    "fundamentals:ingest": "node scripts/run-node22.js scripts/data-ingestion.js",
    "scheduler:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-weekly-alerts.ps1",
    "run:mode": "node scripts/run-node22.js scripts/run-mode.js",
    "security:audit": "node scripts/run-node22.js scripts/security-audit.js"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "yahoo-finance2": "^3.15.2"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
