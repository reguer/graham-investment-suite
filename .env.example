# Graham Investment Suite - configuracion local
#
# Copia estos campos a .env.local en cada ordenador.
# Nunca subas .env.local ni credenciales reales a GitHub.

# PostgreSQL local.
# Formato exacto:
# DATABASE_URL=postgresql://USUARIO:PASSWORD@127.0.0.1:5432/graham_suite
DATABASE_URL=

# Captura diaria local.
# Si esta en true, el dashboard local programa una corrida diaria a CAPTURE_LOCAL_TIME
# mientras npm run dev:safe este abierto.
ENABLE_DAILY_CAPTURE=true
CAPTURE_LOCAL_TIME=18:00

# Telegram queda apagado hasta que tu configures bot y chat.
ENABLE_TELEGRAM_ALERTS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_MIN_SEVERITY=medium
